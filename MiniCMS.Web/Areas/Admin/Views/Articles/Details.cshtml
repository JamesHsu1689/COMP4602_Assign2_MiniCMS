@model MiniCMS.Web.Models.Article

@{
    ViewData["Title"] = "Article Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Details</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Articles" asp-action="Index">Back</a>
        <a class="btn btn-primary" asp-area="Admin" asp-controller="Articles" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h2 class="h4">@Model.Title</h2>
        <div class="text-muted mb-3">
            <div><strong>Created:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
            <div><strong>Updated:</strong> @Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
        </div>

        <hr />

        <div>
            @* Content is stored sanitized; render as HTML *@
            @Html.Raw(Model.Content)
        </div>
    </div>
</div>