@model MiniCMS.Web.Models.Article

@{
    ViewData["Title"] = "Delete Article";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Delete</h1>
    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Articles" asp-action="Index">Back</a>
</div>

<div class="alert alert-warning">
    Are you sure you want to delete this article? This cannot be undone.
</div>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h5 mb-2">@Model.Title</h2>
        <div class="text-muted">
            <div><strong>Created:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
            <div><strong>Updated:</strong> @Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
        </div>
    </div>
</div>

<form asp-area="Admin" asp-controller="Articles" asp-action="Delete" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Yes, delete</button>
    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Articles" asp-action="Index">Cancel</a>
</form>