@using MiniCMS.Web.Areas.Admin.Models
@model ArticleEditViewModel

@{
    ViewData["Title"] = "Create Article";
}

<!-- Quill CSS (per-view include, simplest) -->
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">

<h1 class="mb-3">Create Article</h1>

<div class="row">
    <div class="col-md-10 col-lg-8">
        <!-- <form asp-action="Create" method="post" novalidate> does not work because there are multiple ArticleController files-->
        <form asp-area="Admin" asp-controller="Articles" asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>

                <!-- Hidden field that actually posts back -->
                <input type="hidden" asp-for="Content" id="Content" />

                <!-- Quill editor UI -->
                <div id="editor" class="border rounded" style="height:300px;"></div>

                <!-- Keep MVC validation message tied to Content -->
                <span asp-validation-for="Content" class="text-danger d-block mt-1"></span>

                <!-- Optional: small client-side message if editor is empty -->
                <small id="quillEmptyMsg" class="text-danger d-none">Content is required.</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- Quill JS (per-view include) -->
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>

    <script>
        (function () {
            var quill = new Quill('#editor', { theme: 'snow' });

            // If we re-render due to validation errors, restore posted Content into editor.
            const initialHtml = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.Content ?? ""));
            if (initialHtml) {
                quill.root.innerHTML = initialHtml;
            }

            // Ensure hidden input is in sync (helps required validation and redisplay)
            var contentInput = document.getElementById('Content');
            function syncHidden() {
                contentInput.value = quill.root.innerHTML;
            }

            // Sync on any change (so client-side required can work)
            quill.on('text-change', function () {
                syncHidden();

                // Optional empty check
                var plain = quill.getText().trim();
                var empty = plain.length === 0;
                document.getElementById('quillEmptyMsg').classList.toggle('d-none', !empty);
            });

            // On submit, final sync (server sanitization remains the authority)
            var form = document.querySelector('form');
            form.addEventListener('submit', function (e) {
                syncHidden();

                // Optional: prevent submit if empty (client-side nicety; server still validates)
                var plain = quill.getText().trim();
                if (plain.length === 0) {
                    document.getElementById('quillEmptyMsg').classList.remove('d-none');
                    // Let MVC validation handle required too; this just improves UX
                    // If you prefer not to block submit, remove the next 2 lines.
                    e.preventDefault();
                    e.stopPropagation();
                }
            });

            // Initial sync so Content isn't null if user submits without typing
            syncHidden();
        })();
    </script>
}