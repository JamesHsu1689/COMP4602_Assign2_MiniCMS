@page "/articles/{id:int}"
@using MiniCMS.Client.Models
@using System.Net
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components
@inject HttpClient Http

<PageTitle>Article Detail</PageTitle>

<section class="page-section">
    @if (isLoading)
    {
        <p class="status-message">Loading article...</p>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <p class="status-message error-message">@errorMessage</p>
    }
    else if (article is null)
    {
        <p class="status-message">Article not found.</p>
    }
    else
    {
        <article class="article-detail">
            <header class="article-detail-header">
                <h1 class="article-detail-title">@article.Title</h1>

                <div class="article-meta">
                    <span>Created: @article.CreatedAt.ToString("g")</span>
                    <span>Updated: @article.UpdatedAt.ToString("g")</span>
                </div>
            </header>

            <div class="article-detail-content">
                @((MarkupString)article.Content)
            </div>
        </article>
    }
</section>

@code {
    [Parameter]
    public int Id { get; set; }

    private ArticleDetailDto? article;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        article = null;

        try
        {
            var response = await Http.GetAsync($"api/articles/public/{Id}");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                article = null;
            }
            else if (response.IsSuccessStatusCode)
            {
                article = await response.Content.ReadFromJsonAsync<ArticleDetailDto>();
            }
            else
            {
                errorMessage = $"Failed to load article. Status: {(int)response.StatusCode} {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load article. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}